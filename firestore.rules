rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Capstone default: any signed-in user can read dashboard data.
    // Writes should come from trusted backend services (Admin SDK bypasses rules).
    match /repos/{repoId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /scan_runs/{scanId} {
        allow read: if request.auth != null;
        allow write: if false;

        match /issues/{issueId} {
          allow read: if request.auth != null;
          allow write: if false;
        }
      }

      match /fingerprint_baselines/{baselineId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
